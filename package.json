    "konva": "^10.3.0",
    "mathjs": "^15.2.0",
    "plotly.js-dist": "^3.5.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-konva": "^19.2.4",
    "react-plotly.js": "^2.6.0",
    "use-image": "^1.1.4",
